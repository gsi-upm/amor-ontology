        <ns:hasMoralValueCategory rdf:resource="http://www.gsi.upm.es/ontologies/mft/ns#Purity"/>
        <rdfs:comment xml:lang="en">This model uses a consolidated category set from Moral Foundations Theory to define the moral values of the annotated content.</rdfs:comment>
