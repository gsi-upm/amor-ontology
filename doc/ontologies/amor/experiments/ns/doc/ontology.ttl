:SentimentDisimilarity a :RecommendationCriterion,
        owl:NamedIndividual ;
    rdfs:label "Opposite Sentiment Recommendation Strategy"@en ;
    rdfs:comment "Recommends elements with an opposite sentiment value"@en .

